# Database Connection URL (Supabase Pooler/Connection String)
DATABASE_URL=your_supabase_db_url_here

# Groq API Key for AI Agents
GROQ_API_KEY=your_groq_api_key_here

# Redis Broker URL (Defaults to local redis_broker container in docker-compose)
REDIS_URL=redis://localhost:6373/0

# Environment Mode (development or production)
ENV=development
